# Sanity CMS
# Get these from https://sanity.io/manage after creating your project
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Required for server-side draft previews and mutations
# Create a token at sanity.io/manage > API > Tokens (Editor role)
SANITY_API_TOKEN=your_token_here

# Formspree — get your form ID at https://formspree.io
# Create a new form and paste the ID (e.g. xrgndkjw) here
NEXT_PUBLIC_FORMSPREE_FORM_ID=your_formspree_id_here

# Site URL — used for canonical tags and OG metadata
NEXT_PUBLIC_SITE_URL=https://www.msmadvocates.co.ug
